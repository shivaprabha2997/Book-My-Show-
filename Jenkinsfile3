pipeline {
    agent any

    tools {
        jdk 'JDK21'
        nodejs 'nodejs23'
    }

    environment {
        SCANNER_HOME = tool 'sq'
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'main',
                url: 'https://github.com/shivaprabha2997/Book-My-Show-.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                    $SCANNER_HOME/bin/sonar-scanner \
                    -Dsonar.projectName=BMS \
                    -Dsonar.projectKey=BMS
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false,
                    credentialsId: 'sq'
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                cd bookmyshow-app

                rm -rf node_modules
                rm -rf package-lock.json

                npm install
                '''
            }
        }

        stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs . > trivyfs.txt'
            }
        }

        stage('Docker Build & Push') {
            steps {

                script {

                    withDockerRegistry(
                    credentialsId: 'shivadocker_cred',
                    toolName: 'docker') {

                        sh '''
                        docker build -t shivadocker2997/bms:latest \
                        -f bookmyshow-app/Dockerfile \
                        bookmyshow-app

                        docker push shivadocker2997/bms:latest
                        '''
                    }
                }
            }
        }

        stage('Deploy Container') {
            steps {

                sh '''
                docker stop bms || true

                docker rm bms || true

                docker run -d \
                --name bms \
                -p 3000:3000 \
                YOUR_DOCKER_USERNAME/bms:latest
                '''
            }
        }
    }
}
